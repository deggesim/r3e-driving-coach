{
  "name": "r3e-driving-coach",
  "version": "0.1.0",
  "description": "R3E Voice Coach — real-time driving coach for RaceRoom Racing Experience",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:vite": "vite",
    "build": "tsc && vite build",
    "build:electron": "npm run build && electron-builder",
    "test:reader": "ts-node src/main/r3e/r3e-reader.ts",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "rebuild:native": "electron-rebuild -f -w ffi-napi,ref-napi,better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "electron-store": "^8.2.0",
    "ffi-napi": "^4.0.3",
    "jspdf": "^2.5.2",
    "marked": "^15.0.0",
    "ref-napi": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/ffi-napi": "^4.0.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ref-napi": "^3.0.12",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^30.5.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.r3ecoach.app",
    "productName": "R3E Coach",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ]
  }
}
